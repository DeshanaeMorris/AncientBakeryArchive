<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>


<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ancientbakery.ancientbakeryarchive.AncientController"
            stylesheets="@../styles.css"
            styleClass="era-screen"
            prefHeight="600.0" prefWidth="800.0">

    <VBox layoutY="60" layoutX="20" prefWidth="150" prefHeight="520"
          spacing="10" alignment="CENTER" styleClass="era-sidebar">

        <Button text="Ancient" styleClass="sidebar-link" onAction="#goAncient"/>
        <Button text="Medieval" styleClass="sidebar-link" onAction="#goMedieval"/>
        <Button text="Renaissance" styleClass="sidebar-link" onAction="#goRenaissance"/>
        <Button text="Industrial" styleClass="sidebar-link" onAction="#goIndustrial"/>
        <Button text="20th Century" styleClass="sidebar-link" onAction="#go20thCent"/>
        <Button text="Modern" styleClass="sidebar-link" onAction="#goModern"/>

        <Button text="BAKE NOW" styleClass="bake-now" prefHeight="50" prefWidth="120" onAction="#goBakeNow"/>

    </VBox>

    <TabPane layoutX="185" layoutY="20" prefWidth="595" prefHeight="560"
             tabClosingPolicy="UNAVAILABLE" styleClass="era-tabs">

        <Tab text="RECIPES">
            <VBox styleClass="parchment-ancient" alignment="TOP_CENTER" spacing="15" pickOnBounds="false">
                <padding><Insets top="25" right="20" left="20" bottom="20"/></padding>

                <ListView fx:id="recipeListView" prefHeight="120.0" prefWidth="Infinity" onMouseClicked="#handleRecipeClick"/>

                <VBox fx:id="recipeDetailPane" spacing="8" alignment="TOP_LEFT" visible="false">
                    <Label fx:id="recipeNameLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4a2c11;"/>
                    <Label fx:id="recipeSourceLabel" style="-fx-font-style: italic; -fx-text-fill: #6e4720;"/>
                    <Label fx:id="recipeTempLabel" style="-fx-text-fill: #4a2c11;"/>

                    <Label text="Original Text:" style="-fx-font-weight: bold; -fx-text-fill: #4a2c11;"/>
                    <Label fx:id="recipeOriginalLabel" wrapText="true" style="-fx-text-fill: #5c4028;"/>

                    <Label text="Modern Method (Available in BAKE NOW):" style="-fx-font-weight: bold; -fx-text-fill: #4a2c11;"/>
                    <Label fx:id="recipeModernLabel" wrapText="true" style="-fx-text-fill: #5c4028;"/>
                </VBox>
            </VBox>
        </Tab>

        <Tab text="PICTURES">
            <StackPane styleClass="parchment-ancient">
                <Label text="Pictures coming soon" styleClass="recipe-title"/>
            </StackPane>
        </Tab>

        <Tab text="HISTORY">
            <StackPane styleClass="parchment-ancient">
                <Label text="History coming soon" styleClass="recipe-title"/>
            </StackPane>
        </Tab>

        <Tab text="POPULAR">
            <StackPane styleClass="parchment-ancient">
                <Label text="Popular coming soon" styleClass="recipe-title"/>
            </StackPane>
        </Tab>
    </TabPane>

</AnchorPane>
