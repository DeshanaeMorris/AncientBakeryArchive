<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ancientbakery.ancientbakeryarchive.AnalyticsHubController"
            stylesheets="@../styles.css"
            styleClass="analytics-page"
            prefWidth="900.0"
            prefHeight="700.0"
            minWidth="700.0"
            minHeight="500.0">

    <VBox spacing="20"
          AnchorPane.topAnchor="20"
          AnchorPane.bottomAnchor="20"
          AnchorPane.leftAnchor="20"
          AnchorPane.rightAnchor="20">

        <padding>
            <Insets top="18" right="14" bottom="14" left="14"/>
        </padding>

        <!-- Banner -->
        <StackPane>
            <Pane styleClass="hero-image" maxWidth="Infinity" prefHeight="200"/>

            <VBox styleClass="hero-banner"
                  spacing="8"
                  alignment="BOTTOM_LEFT"
                  minHeight="140">

                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>

                <Label text="Analytics Hub"
                       styleClass="hero-title"/>

                <Button text="← Back"
                        styleClass="hero-back-button"
                        onAction="#goBack"/>


            </VBox>
        </StackPane>

        <!-- KPI Cards -->

        <GridPane hgap="16">

            <columnConstraints>
                <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
            </columnConstraints>

            <VBox GridPane.columnIndex="0"
                  styleClass="analytics-kpi-card"
                  alignment="CENTER"
                  spacing="5"
                  minHeight="90"
                  maxWidth="Infinity">

                <Label text="Total Recipes"
                       styleClass="analytics-kpi-label"/>

                <Label fx:id="totalRecipesLabel"
                       text="0"
                       styleClass="analytics-kpi-value"/>

            </VBox>

            <VBox GridPane.columnIndex="1"
                  styleClass="analytics-kpi-card"
                  alignment="CENTER"
                  spacing="5"
                  minHeight="90"
                  maxWidth="Infinity">

                <Label text="Eras Covered"
                       styleClass="analytics-kpi-label"/>

                <Label fx:id="totalErasLabel"
                       text="0"
                       styleClass="analytics-kpi-value"/>

            </VBox>

            <VBox GridPane.columnIndex="2"
                  styleClass="analytics-kpi-card"
                  alignment="CENTER"
                  spacing="5"
                  minHeight="90"
                  maxWidth="Infinity">

                <Label text="Most Complex Recipe"
                       wrapText="true"
                       styleClass="analytics-kpi-label"/>

                <Label fx:id="complexRecipeLabel"
                       text="N/A"
                       wrapText="true"
                       styleClass="analytics-kpi-value-small"/>

            </VBox>

            <VBox GridPane.columnIndex="3"
                  styleClass="analytics-kpi-card"
                  alignment="CENTER"
                  spacing="5"
                  minHeight="90"
                  maxWidth="Infinity">

                <Label text="Top Archive Ingredient"
                       wrapText="true"
                       styleClass="analytics-kpi-label"/>

                <Label fx:id="ancientIngredientLabel"
                       text="N/A"
                       wrapText="true"
                       styleClass="analytics-kpi-value-small"/>

            </VBox>

        </GridPane>

        <Label text="Choose a report"
               styleClass="analytics-section-title"
               maxWidth="Infinity"/>

        <!-- Report Grid -->

        <GridPane hgap="22"
                  vgap="22"
                  VBox.vgrow="ALWAYS">

            <columnConstraints>
                <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
            </columnConstraints>

            <rowConstraints>
                <RowConstraints vgrow="ALWAYS"/>
                <RowConstraints vgrow="ALWAYS"/>
            </rowConstraints>

            <!-- Cooking Fats -->

            <Button GridPane.columnIndex="0"
                    GridPane.rowIndex="0"
                    maxWidth="Infinity"
                    maxHeight="Infinity"
                    styleClass="analytics-report-card"
                    onAction="#goCookingFats">

                <graphic>
                    <VBox alignment="CENTER" spacing="10">

                        <Label text="📊"
                               styleClass="analytics-report-icon"/>

                        <Label text="Cooking Fats"
                               styleClass="analytics-report-title"/>

                        <Label text="Leaderboard"
                               styleClass="analytics-report-subtitle"/>

                    </VBox>
                </graphic>

            </Button>

            <!-- Sweeteners -->

            <Button GridPane.columnIndex="1"
                    GridPane.rowIndex="0"
                    maxWidth="Infinity"
                    maxHeight="Infinity"
                    styleClass="analytics-report-card"
                    onAction="#goSweeteners">

                <graphic>
                    <VBox alignment="CENTER" spacing="10">

                        <Label text="📈"
                               styleClass="analytics-report-icon"/>

                        <Label text="Sweeteners"
                               styleClass="analytics-report-title"/>

                        <Label text="Line graph"
                               styleClass="analytics-report-subtitle"/>

                    </VBox>
                </graphic>

            </Button>

            <!-- Yeast Timeline -->

            <Button GridPane.columnIndex="0"
                    GridPane.rowIndex="1"
                    maxWidth="Infinity"
                    maxHeight="Infinity"
                    styleClass="analytics-report-card"
                    onAction="#goYeastTimeline">

                <graphic>
                    <VBox alignment="CENTER" spacing="10">

                        <Label text="⏳"
                               styleClass="analytics-report-icon"/>

                        <Label text="Yeast Timeline"
                               styleClass="analytics-report-title"/>

                        <Label text="Rising agents"
                               styleClass="analytics-report-subtitle"/>

                    </VBox>
                </graphic>

            </Button>

            <!-- Era Breakdown -->

            <Button GridPane.columnIndex="1"
                    GridPane.rowIndex="1"
                    maxWidth="Infinity"
                    maxHeight="Infinity"
                    styleClass="analytics-report-card"
                    onAction="#goEraBreakdown">

                <graphic>
                    <VBox alignment="CENTER" spacing="10">

                        <Label text="🥧"
                               styleClass="analytics-report-icon"/>

                        <Label text="Era Breakdown"
                               styleClass="analytics-report-title"/>

                        <Label text="Pie chart"
                               styleClass="analytics-report-subtitle"/>

                    </VBox>
                </graphic>

            </Button>

        </GridPane>

    </VBox>

</AnchorPane>