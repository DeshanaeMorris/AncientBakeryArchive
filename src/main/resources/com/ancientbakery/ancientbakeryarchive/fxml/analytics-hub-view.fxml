<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ancientbakery.ancientbakeryarchive.AnalyticsHubController"
            stylesheets="@../styles.css"
            styleClass="era-screen"
            prefHeight="600.0" prefWidth="800.0"
            minHeight="500.0" minWidth="700.0">

    <VBox AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0"
          AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0"
          styleClass="conversions-panel" spacing="20">
        <padding>
            <Insets top="18" right="14" bottom="14" left="14"/>
        </padding>

        <Label text="Analytics Hub - Archive Dashboard" styleClass="recipe-title-small"/>

        <Button text="← Back" styleClass="sidebar-link"
                prefWidth="100" prefHeight="36"
                onAction="#goBack"/>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <VBox styleClass="analytics-card" alignment="CENTER" spacing="5"
                  prefWidth="180" prefHeight="80">
                <Label text="Total Recipes" style="-fx-font-size: 14; -fx-text-fill: #8a7560;"/>
                <Label fx:id="totalRecipesLabel" text="0"
                       style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #3b2314;"/>
            </VBox>
            <VBox styleClass="analytics-card" alignment="CENTER" spacing="5"
                  prefWidth="180" prefHeight="80">
                <Label text="Eras Covered" style="-fx-font-size: 14; -fx-text-fill: #8a7560;"/>
                <Label fx:id="totalErasLabel" text="0"
                       style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #3b2314;"/>
            </VBox>

            <VBox styleClass="analytics-card" alignment="CENTER" spacing="5"
                  prefWidth="160" prefHeight="80">
                <Label text="Most Complex Recipe" style="-fx-font-size: 13; -fx-text-fill: #8a7560;"/>
                <Label fx:id="complexRecipeLabel" text="N/A" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #3b2314;" wrapText="true" alignment="CENTER"/>
            </VBox>

            <VBox styleClass="analytics-card" alignment="CENTER" spacing="5"
                  prefWidth="160" prefHeight="80">
                <Label text="Top Archive Ingredient" style="-fx-font-size: 13; -fx-text-fill: #8a7560;"/>
                <Label fx:id="ancientIngredientLabel" text="N/A" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #3b2314;" wrapText="true" alignment="CENTER"/>
            </VBox>
        </HBox>

        <Separator/>

        <Label text="Choose a report" styleClass="recipe-subtitle"/>

        <HBox spacing="16" alignment="TOP_LEFT">
            <Button onAction="#goCookingFats" styleClass="analytics-card, analytics-card-button"
                    prefWidth="160" prefHeight="120">
                <graphic>
                    <VBox alignment="CENTER" spacing="6">
                        <Label text="📊" style="-fx-font-size: 22;"/>
                        <Label text="Cooking Fats"
                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #3b2314;"/>
                        <Label text="Leaderboard" style="-fx-font-size: 12; -fx-text-fill: #8a7560;"/>
                    </VBox>
                </graphic>
            </Button>

            <Button onAction="#goSweeteners" styleClass="analytics-card, analytics-card-button"
                    prefWidth="160" prefHeight="120">
                <graphic>
                    <VBox alignment="CENTER" spacing="6">
                        <Label text="📈" style="-fx-font-size: 22;"/>
                        <Label text="Sweeteners"
                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #3b2314;"/>
                        <Label text="Line graph" style="-fx-font-size: 12; -fx-text-fill: #8a7560;"/>
                    </VBox>
                </graphic>
            </Button>

            <Button onAction="#goYeastTimeline" styleClass="analytics-card, analytics-card-button"
                    prefWidth="160" prefHeight="120">
                <graphic>
                    <VBox alignment="CENTER" spacing="6">
                        <Label text="⏳" style="-fx-font-size: 22;"/>
                        <Label text="Yeast Timeline"
                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #3b2314;"/>
                        <Label text="Rising agents" style="-fx-font-size: 12; -fx-text-fill: #8a7560;"/>
                    </VBox>
                </graphic>
            </Button>
        </HBox>

        <Button onAction="#goEraBreakdown" styleClass="analytics-card, analytics-card-button"
                prefWidth="160" prefHeight="120">
            <graphic>
                <VBox alignment="CENTER" spacing="6">
                    <Label text="🥧" style="-fx-font-size: 22;"/>
                    <Label text="Era Breakdown" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #3b2314;"/>
                    <Label text="Pie chart" style="-fx-font-size: 12; -fx-text-fill: #8a7560;"/>
                </VBox>
            </graphic>
        </Button>

    </VBox>
</AnchorPane>