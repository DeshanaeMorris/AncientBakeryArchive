<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ancientbakery.ancientbakeryarchive.IndustrialController"
            stylesheets="@../styles.css"
            styleClass="era-screen"
            prefHeight="600.0" prefWidth="800.0"
            minHeight="500.0" minWidth="700.0">

    <VBox AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="58.0" AnchorPane.bottomAnchor="20.0"
          prefWidth="150" spacing="10" alignment="CENTER" styleClass="era-sidebar">

        <Button text="Ancient" styleClass="sidebar-link" onAction="#goAncient"/>
        <Button text="Medieval" styleClass="sidebar-link" onAction="#goMedieval"/>
        <Button text="Renaissance" styleClass="sidebar-link" onAction="#goRenaissance"/>
        <Button text="Industrial" styleClass="sidebar-link" onAction="#goIndustrial"/>
        <Button text="20th Century" styleClass="sidebar-link" onAction="#go20thCent"/>
        <Button text="Modern" styleClass="sidebar-link" onAction="#goModern"/>

        <Button text="BAKE NOW" styleClass="bake-now" prefHeight="50" prefWidth="120" onAction="#goBakeNow"/>

    </VBox>

    <TabPane AnchorPane.leftAnchor="185.0" AnchorPane.topAnchor="20.0"
             AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0"
             tabClosingPolicy="UNAVAILABLE" styleClass="era-tabs">

        <Tab text="RECIPES">
            <BorderPane styleClass="parchment-industrial" minWidth="0.0" minHeight="0.0">
                <top>
                    <VBox fx:id="eraTitleBox" alignment="CENTER" maxWidth="560"
                          spacing="4" styleClass="era-intro-overlay"
                          BorderPane.alignment="CENTER">
                        <BorderPane.margin>
                            <Insets top="34" right="32" bottom="16" left="32"/>
                        </BorderPane.margin>
                        <padding>
                            <Insets top="14" right="20" bottom="14" left="20"/>
                        </padding>
                    </VBox>
                </top>

                <center>
                    <StackPane alignment="TOP_CENTER">
                        <BorderPane.margin>
                            <Insets top="0" right="0" bottom="0" left="0"/>
                        </BorderPane.margin>
                        <ScrollPane fitToWidth="true" styleClass="recipe-scroll"
                                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    maxWidth="820" StackPane.alignment="TOP_CENTER">
                            <StackPane.margin>
                                <Insets top="4" right="26" bottom="24" left="26"/>
                            </StackPane.margin>
                            <VBox fx:id="recipeCardsBox" alignment="TOP_CENTER"
                                  styleClass="recipe-cards-content" spacing="14">
                                <padding>
                                    <Insets top="6" right="6" bottom="24" left="6"/>
                                </padding>
                            </VBox>
                        </ScrollPane>
                    </StackPane>
                </center>
            </BorderPane>
        </Tab>

        <Tab text="PICTURES">
            <StackPane styleClass="parchment-industrial">
                <Label text="Pictures coming soon" styleClass="recipe-title"/>
            </StackPane>
        </Tab>

        <Tab text="HISTORY">
            <StackPane styleClass="parchment-industrial">
                <Label text="History coming soon" styleClass="recipe-title"/>
            </StackPane>
        </Tab>

        <Tab text="POPULAR">
            <StackPane styleClass="parchment-industrial">
                <Label text="Popular coming soon" styleClass="recipe-title"/>
            </StackPane>
        </Tab>
    </TabPane>

</AnchorPane>
