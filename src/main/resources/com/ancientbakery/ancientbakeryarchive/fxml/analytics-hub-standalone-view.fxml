<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ancientbakery.ancientbakeryarchive.AnalyticsHubController"
            stylesheets="@../styles.css"
            styleClass="era-screen"
            prefHeight="600.0" prefWidth="800.0"
            minHeight="500.0" minWidth="700.0">

    <VBox AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="58.0" AnchorPane.bottomAnchor="20.0"
          prefWidth="150" spacing="10" alignment="TOP_CENTER" styleClass="era-sidebar">

        <VBox spacing="5" alignment="CENTER">
            <padding>
                <Insets top="10" right="10" bottom="15" left="10"/>
            </padding>
            <StackPane prefWidth="130" maxWidth="140">
                <TextField fx:id="searchField" promptText="Search..."
                           onAction="#handleSearch" prefWidth="130"
                           styleClass="search-field"/>
                <Label text="🔍" styleClass="search-icon"
                       StackPane.alignment="CENTER_LEFT"
                       translateX="6"/>
            </StackPane>

            <ListView fx:id="searchResultsList"
                      prefWidth="130"
                      maxWidth="140"
                      minHeight="100"
                      prefHeight="120"
                      maxHeight="150"
                      managed="false"
                      visible="false"
                      styleClass="search-results"/>
        </VBox>
        <Button text="Ancient" styleClass="sidebar-link" onAction="#goAncient"/>
        <Button text="Medieval" styleClass="sidebar-link" onAction="#goMedieval"/>
        <Button text="Renaissance" styleClass="sidebar-link" onAction="#goRenaissance"/>
        <Button text="Industrial" styleClass="sidebar-link" onAction="#goIndustrial"/>
        <Button text="20th Century" styleClass="sidebar-link" onAction="#go20thCent"/>
        <Button text="Modern" styleClass="sidebar-link" onAction="#goModern"/>

        <Button text="BAKE NOW" styleClass="bake-now" prefHeight="50" prefWidth="120" onAction="#goBakeNow"/>
        <Button text="Go Back" styleClass="sidebar-link" onAction="#goToContents"/>

    </VBox>

    <TabPane fx:id="standaloneTabPane" AnchorPane.leftAnchor="185.0" AnchorPane.topAnchor="20.0"
             AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0"
             tabClosingPolicy="UNAVAILABLE" styleClass="era-tabs">

        <Tab text="RECIPES" closable="false"/>
        <Tab text="PICTURES" closable="false"/>
        <Tab text="HISTORY" closable="false"/>


        <Tab text="ANALYTICS HUB" closable="false">
            <VBox styleClass="analytics-page" spacing="20">
                <padding>
                    <Insets top="18" right="14" bottom="14" left="14"/>
                </padding>

                <VBox styleClass="hero-banner" alignment="BOTTOM_LEFT" prefHeight="180" spacing="8">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>
                    <Label text="Analytics Hub" styleClass="hero-title"/>
                </VBox>

                <GridPane hgap="16">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25" minWidth="0"/>
                        <ColumnConstraints percentWidth="25" minWidth="0"/>
                        <ColumnConstraints percentWidth="25" minWidth="0"/>
                        <ColumnConstraints percentWidth="25" minWidth="0"/>
                    </columnConstraints>

                    <VBox styleClass="analytics-kpi-card" alignment="CENTER" spacing="5"
                          minWidth="0" prefHeight="90" GridPane.columnIndex="0">
                        <Label text="Total Recipes" styleClass="analytics-kpi-label"/>
                        <Label fx:id="totalRecipesLabel" text="0" styleClass="analytics-kpi-value"/>
                    </VBox>
                    <VBox styleClass="analytics-kpi-card" alignment="CENTER" spacing="5"
                          minWidth="0" prefHeight="90" GridPane.columnIndex="1">
                        <Label text="Eras Covered" styleClass="analytics-kpi-label"/>
                        <Label fx:id="totalErasLabel" text="0" styleClass="analytics-kpi-value"/>
                    </VBox>
                    <VBox styleClass="analytics-kpi-card" alignment="CENTER" spacing="5"
                          minWidth="0" prefHeight="90" GridPane.columnIndex="2">
                        <Label text="Most Complex Recipe" styleClass="analytics-kpi-label" wrapText="true"/>
                        <Label fx:id="complexRecipeLabel" text="N/A" styleClass="analytics-kpi-value-small" wrapText="true"/>
                    </VBox>
                    <VBox styleClass="analytics-kpi-card" alignment="CENTER" spacing="5"
                          minWidth="0" prefHeight="90" GridPane.columnIndex="3">
                        <Label text="Top Archive Ingredient" styleClass="analytics-kpi-label" wrapText="true"/>
                        <Label fx:id="ancientIngredientLabel" text="N/A" styleClass="analytics-kpi-value-small" wrapText="true"/>
                    </VBox>
                </GridPane>

                <Label text="Choose a report" styleClass="analytics-section-title" alignment="CENTER" maxWidth="Infinity"/>

                <GridPane hgap="22" vgap="22" alignment="CENTER">
                    <Button onAction="#goCookingFats" styleClass="analytics-report-card"
                            prefWidth="220" prefHeight="160" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <graphic>
                            <VBox alignment="CENTER" spacing="10">
                                <Label text="📊" styleClass="analytics-report-icon"/>
                                <Label text="Cooking Fats" styleClass="analytics-report-title"/>
                                <Label text="Leaderboard" styleClass="analytics-report-subtitle"/>
                            </VBox>
                        </graphic>
                    </Button>

                    <Button onAction="#goSweeteners" styleClass="analytics-report-card"
                            prefWidth="220" prefHeight="160" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <graphic>
                            <VBox alignment="CENTER" spacing="10">
                                <Label text="📈" styleClass="analytics-report-icon"/>
                                <Label text="Sweeteners" styleClass="analytics-report-title"/>
                                <Label text="Line graph" styleClass="analytics-report-subtitle"/>
                            </VBox>
                        </graphic>
                    </Button>

                    <Button onAction="#goYeastTimeline" styleClass="analytics-report-card"
                            prefWidth="220" prefHeight="160" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <graphic>
                            <VBox alignment="CENTER" spacing="10">
                                <Label text="⏳" styleClass="analytics-report-icon"/>
                                <Label text="Yeast Timeline" styleClass="analytics-report-title"/>
                                <Label text="Rising agents" styleClass="analytics-report-subtitle"/>
                            </VBox>
                        </graphic>
                    </Button>

                    <Button onAction="#goEraBreakdown" styleClass="analytics-report-card"
                            prefWidth="220" prefHeight="160" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <graphic>
                            <VBox alignment="CENTER" spacing="10">
                                <Label text="🥧" styleClass="analytics-report-icon"/>
                                <Label text="Era Breakdown" styleClass="analytics-report-title"/>
                                <Label text="Pie chart" styleClass="analytics-report-subtitle"/>
                            </VBox>
                        </graphic>
                    </Button>
                </GridPane>

            </VBox>
        </Tab>
    </TabPane>

</AnchorPane>
