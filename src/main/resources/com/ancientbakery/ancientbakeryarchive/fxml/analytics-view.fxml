<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ancientbakery.ancientbakeryarchive.AnalyticsController"
            stylesheets="@../styles.css"
            styleClass="era-screen"
            prefHeight="600.0" prefWidth="800.0"
            minHeight="500.0" minWidth="700.0">

    <VBox AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="60.0" AnchorPane.bottomAnchor="20.0"
          prefWidth="150" spacing="10" alignment="CENTER" styleClass="era-sidebar">

        <Button text="Ancient" styleClass="sidebar-link" onAction="#goAncient"/>
        <Button text="Medieval" styleClass="sidebar-link" onAction="#goMedieval"/>
        <Button text="Renaissance" styleClass="sidebar-link" onAction="#goRenaissance"/>
        <Button text="Industrial" styleClass="sidebar-link" onAction="#goIndustrial"/>
        <Button text="20th Century" styleClass="sidebar-link" onAction="#go20thCent"/>
        <Button text="Modern" styleClass="sidebar-link" onAction="#goModern"/>


        <Button text="BAKE NOW" styleClass="bake-now" prefHeight="50" prefWidth="120" onAction="#goBakeNow"/>
        <Button text="ANALYTICS" styleClass="bake-now" prefHeight="50" prefWidth="120" onAction="#goAnalytics"/>
    </VBox>

    <!-- Main Dash Workspace -->
    <VBox AnchorPane.leftAnchor="185.0" AnchorPane.topAnchor="20.0"
          AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0"
          styleClass="conversions-panel" spacing="20">
        <padding>
            <Insets top="18" right="14" bottom="14" left="14"/>
        </padding>

        <Label text="Analytics Hub - Archive Dashboard" styleClass="recipe-title-small"/>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <VBox spacing="5" styleClass="parchment-ancient" prefWidth="180" prefHeight="80" alignment="CENTER">
                <Label text="Total Recipes" style="-fx-font-size: 14;"/>
                <Label fx:id="totalRecipesLabel" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
            </VBox>
            <VBox spacing="5" styleClass="parchment-ancient" prefWidth="180" prefHeight="80" alignment="CENTER">
                <Label text="Eras Covered" style="-fx-font-size: 14;"/>
                <Label fx:id="totalErasLabel" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>

        <Separator />

        <VBox spacing="10" VBox.vgrow="ALWAYS">
            <Label text="Cooking Fat Frequency Leaderboard" styleClass="recipe-subtitle"/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                <VBox fx:id="leaderboardContainer" spacing="8">
                </VBox>
            </ScrollPane>
        </VBox>
    </VBox>
</AnchorPane>
