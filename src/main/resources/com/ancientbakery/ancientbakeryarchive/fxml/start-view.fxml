<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.geometry.Insets?>
<StackPane prefHeight="600" prefWidth="800" minHeight="500" minWidth="700" styleClass="start-screen" stylesheets="@../styles.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ancientbakery.ancientbakeryarchive.StartController">
    <VBox alignment="CENTER" spacing="60" maxWidth="560" maxHeight="420" styleClass="welcome-card">
        <padding>
            <Insets top="40" right="50" bottom="40" left="50"/>
        </padding>

        <ImageView fx:id="titleImageView" fitWidth="400" preserveRatio="true">
            <Image url="@../images/title.png" />
        </ImageView>

        <Button fx:id="welcomeButton" onAction="#onWelcomeClick" prefHeight="70" prefWidth="190" styleClass="welcome-button" text="WELCOME!" />
    </VBox>

</StackPane>
