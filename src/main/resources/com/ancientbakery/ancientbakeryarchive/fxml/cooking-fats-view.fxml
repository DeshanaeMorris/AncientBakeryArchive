<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ancientbakery.ancientbakeryarchive.CookingFatsController"
            stylesheets="@../styles.css"
            styleClass="era-screen"
            prefHeight="600.0" prefWidth="800.0"
            minHeight="500.0" minWidth="700.0">

    <VBox AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0"
          AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0"
          styleClass="conversions-panel" spacing="20">
        <padding>
            <Insets top="18" right="14" bottom="14" left="14"/>
        </padding>

        <Label text="Cooking Fat Frequency Leaderboard" styleClass="recipe-title-small"/>

        <Label text="Cooking Fat Frequency Leaderboard" styleClass="recipe-title-small"/>

        <Button text="← Back" styleClass="sidebar-link"
                prefWidth="100" prefHeight="36"
                onAction="#goBack"/>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
            <VBox fx:id="leaderboardContainer" spacing="8">
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>